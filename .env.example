# Scott's Fresh Kitchens V2 — Environment Variables
# Copy this to .env.local and fill in your values

# Salesforce Connected App (Client Credentials flow)
SF_INSTANCE_URL=https://YOUR_ORG.my.salesforce.com
SF_CLIENT_ID=your_connected_app_client_id
SF_CLIENT_SECRET=your_connected_app_client_secret

# Agentforce Agent ID
SF_AGENT_ID=your_agentforce_agent_id

# Gemini API Key (optional — server-side STT fallback for platforms without Web Speech API)
GEMINI_API_KEY=your_google_ai_studio_api_key

# V2 NOTE: ElevenLabs is NO LONGER NEEDED.
# TTS uses browser-native speechSynthesis (free, zero-latency).
