# Fly Delta Voice App — Environment Variables
# Copy this to .env.local and fill in your values

# Salesforce Connected App (Client Credentials flow)
SF_INSTANCE_URL=https://YOUR_ORG.my.salesforce.com
SF_CLIENT_ID=your_connected_app_client_id
SF_CLIENT_SECRET=your_connected_app_client_secret

# Agentforce Agent ID
SF_AGENT_ID=your_agentforce_agent_id

# Demo Persona (pre-fills customer info)
DEMO_CUSTOMER_NAME=Marcus Johnson
DEMO_CUSTOMER_PHONE=555-0100
DEMO_CUSTOMER_EMAIL=marcus.johnson@example.com

# Gemini API Key (optional — server-side STT fallback + TTS)
GEMINI_API_KEY=your_google_ai_studio_api_key
